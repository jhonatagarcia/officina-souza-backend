generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ATENDENTE
  MECANICO
  FINANCEIRO
}

enum BudgetStatus {
  PENDENTE
  APROVADO
  REPROVADO
}

enum BudgetItemType {
  PART
  LABOR
}

enum ServiceOrderStatus {
  ABERTA
  EM_ANDAMENTO
  FINALIZADA
  ENTREGUE
}

enum FinancialEntryType {
  RECEIVABLE
  PAYABLE
}

enum FinancialStatus {
  PENDENTE
  PAGO
  VENCIDO
}

enum PaymentMethod {
  DINHEIRO
  PIX
  CARTAO_CREDITO
  CARTAO_DEBITO
  BOLETO
  TRANSFERENCIA
  OUTRO
}

enum ServiceBillingType {
  LABOR_ONLY
  PARTS_AND_LABOR
  FIXED_PRICE
}

enum ServiceMaterialSource {
  SHOP_SUPPLIES
  CUSTOMER_SUPPLIES
  NO_PARTS_REQUIRED
  FLEXIBLE
}

model User {
  id             String         @id @default(uuid()) @db.Uuid
  name           String
  email          String         @unique
  passwordHash   String
  role           Role
  isActive       Boolean        @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  serviceOrders  ServiceOrder[] @relation("MechanicServiceOrders")

  @@index([role, isActive])
  @@index([isActive, createdAt])
}

model Client {
  id               String           @id @default(uuid()) @db.Uuid
  name             String
  document         String?          @unique
  phone            String?
  email            String?
  notes            String?
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  vehicles         Vehicle[]
  budgets          Budget[]
  serviceOrders    ServiceOrder[]
  financialEntries FinancialEntry[]

  @@index([name])
  @@index([document])
  @@index([isActive, name])
}

model Vehicle {
  id                String             @id @default(uuid()) @db.Uuid
  clientId          String             @db.Uuid
  plate             String             @unique
  brand             String
  model             String
  year              Int
  color             String?
  mileage           Int?
  fuel              String?
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  client            Client             @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  budgets           Budget[]
  serviceOrders     ServiceOrder[]
  historyEntries    VehicleHistory[]

  @@unique([id, clientId])
  @@index([clientId])
  @@index([plate])
  @@index([clientId, createdAt])
}

model Budget {
  id                     String         @id @default(uuid()) @db.Uuid
  code                   String         @unique
  clientId               String         @db.Uuid
  vehicleId              String         @db.Uuid
  status                 BudgetStatus   @default(PENDENTE)
  problemDescription     String
  notes                  String?
  subtotal               Decimal        @db.Decimal(12, 2)
  discount               Decimal        @db.Decimal(12, 2)
  total                  Decimal        @db.Decimal(12, 2)
  convertedToServiceOrder Boolean       @default(false)
  approvedAt             DateTime?
  rejectedAt             DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  client                 Client         @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  vehicle                Vehicle        @relation(fields: [vehicleId, clientId], references: [id, clientId], onDelete: Restrict, onUpdate: Cascade)
  items                  BudgetItem[]
  serviceOrder           ServiceOrder?

  @@index([clientId])
  @@index([vehicleId])
  @@index([status])
  @@index([clientId, status, createdAt])
  @@index([vehicleId, status, createdAt])
}

model BudgetItem {
  id                   String             @id @default(uuid()) @db.Uuid
  budgetId             String             @db.Uuid
  serviceCatalogItemId String?            @db.Uuid
  type                 BudgetItemType
  serviceCode          String?
  description          String
  quantity             Int
  unitPrice            Decimal            @db.Decimal(12, 2)
  totalPrice           Decimal            @db.Decimal(12, 2)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  budget               Budget             @relation(fields: [budgetId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  serviceCatalogItem   ServiceCatalogItem? @relation(fields: [serviceCatalogItemId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([budgetId])
  @@index([budgetId, type])
  @@index([serviceCatalogItemId])
}

model ServiceOrder {
  id                 String               @id @default(uuid()) @db.Uuid
  orderNumber        String               @unique
  budgetId           String?              @unique @db.Uuid
  clientId           String               @db.Uuid
  vehicleId          String               @db.Uuid
  mechanicId         String?              @db.Uuid
  problemDescription String
  diagnosis          String?
  servicesPerformed  String?
  vehicleChecklist   String?
  openedAt           DateTime             @default(now())
  expectedDeliveryAt DateTime?
  finishedAt         DateTime?
  deliveredAt        DateTime?
  status             ServiceOrderStatus   @default(ABERTA)
  notes              String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  budget             Budget?              @relation(fields: [budgetId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  client             Client               @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  vehicle            Vehicle              @relation(fields: [vehicleId, clientId], references: [id, clientId], onDelete: Restrict, onUpdate: Cascade)
  mechanic           User?                @relation("MechanicServiceOrders", fields: [mechanicId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  parts              ServiceOrderPart[]
  financialEntries   FinancialEntry[]
  historyEntries     VehicleHistory[]

  @@unique([id, clientId])
  @@index([clientId])
  @@index([vehicleId])
  @@index([mechanicId])
  @@index([status])
  @@index([status, openedAt])
  @@index([vehicleId, status, openedAt])
  @@index([mechanicId, status, openedAt])
}

model InventoryItem {
  id               String             @id @default(uuid()) @db.Uuid
  name             String
  internalCode     String             @unique
  category         String?
  supplier         String?
  quantity         Int                @default(0)
  minimumQuantity  Int                @default(0)
  cost             Decimal            @db.Decimal(12, 2)
  salePrice        Decimal            @db.Decimal(12, 2)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  serviceOrderParts ServiceOrderPart[]

  @@index([name])
  @@index([internalCode])
  @@index([category, name])
}

model ServiceCatalogItem {
  id                  String                @id @default(uuid()) @db.Uuid
  code                String                @unique
  name                String
  category            String
  description         String?
  internalNotes       String?
  laborPrice          Decimal               @db.Decimal(12, 2)
  productPrice        Decimal               @db.Decimal(12, 2)
  suggestedTotalPrice Decimal               @db.Decimal(12, 2)
  billingType         ServiceBillingType
  materialSource      ServiceMaterialSource
  warrantyDays        Int?
  active              Boolean               @default(true)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  budgetItems         BudgetItem[]

  @@index([category])
  @@index([name])
  @@index([active])
  @@index([createdAt])
  @@index([active, category, name])
  @@index([active, createdAt])
}

model ServiceOrderPart {
  id              String         @id @default(uuid()) @db.Uuid
  serviceOrderId  String         @db.Uuid
  inventoryItemId String         @db.Uuid
  quantity        Int
  unitPrice       Decimal        @db.Decimal(12, 2)
  totalPrice      Decimal        @db.Decimal(12, 2)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  serviceOrder    ServiceOrder   @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  inventoryItem   InventoryItem  @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([serviceOrderId, inventoryItemId])
  @@index([serviceOrderId])
  @@index([inventoryItemId])
  @@index([inventoryItemId, createdAt])
}

model FinancialEntry {
  id              String             @id @default(uuid()) @db.Uuid
  type            FinancialEntryType
  description     String
  category        String
  amount          Decimal            @db.Decimal(12, 2)
  dueDate         DateTime
  paidAt          DateTime?
  paymentMethod   PaymentMethod?
  status          FinancialStatus    @default(PENDENTE)
  clientId        String?            @db.Uuid
  serviceOrderId  String?            @db.Uuid
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  client          Client?            @relation(fields: [clientId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  serviceOrder    ServiceOrder?      @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([type])
  @@index([status])
  @@index([dueDate])
  @@index([clientId])
  @@index([serviceOrderId])
  @@index([status, dueDate])
  @@index([type, status, dueDate])
}

model VehicleHistory {
  id               String        @id @default(uuid()) @db.Uuid
  vehicleId        String        @db.Uuid
  serviceOrderId   String?       @unique @db.Uuid
  entryDate        DateTime
  mileage          Int?
  servicesSummary  String
  partsSummary     String?
  totalAmount      Decimal?      @db.Decimal(12, 2)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  vehicle          Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  serviceOrder     ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([vehicleId, entryDate])
  @@index([entryDate])
}
