generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ATENDENTE
  MECANICO
  FINANCEIRO
}

enum BudgetStatus {
  PENDENTE
  APROVADO
  REPROVADO
}

enum BudgetItemType {
  PART
  LABOR
  LABOR_AND_PART
}

enum ServiceOrderStatus {
  ABERTA
  EM_ANDAMENTO
  FINALIZADA
  ENTREGUE
}

enum FinancialEntryType {
  RECEIVABLE
  PAYABLE
}

enum FinancialStatus {
  PENDENTE
  PAGO
  VENCIDO
}

enum PaymentMethod {
  DINHEIRO
  PIX
  CARTAO_CREDITO
  CARTAO_DEBITO
  BOLETO
  TRANSFERENCIA
  OUTRO
}

enum ServiceBillingType {
  LABOR_ONLY
  PARTS_AND_LABOR
  FIXED_PRICE
}

enum ServiceMaterialSource {
  SHOP_SUPPLIES
  CUSTOMER_SUPPLIES
  NO_PARTS_REQUIRED
  FLEXIBLE
}

enum InventoryMovementType {
  OUT
  ADJUSTMENT
}

model Workshop {
  id                    String               @id @default(uuid()) @db.Uuid
  tradeName             String
  cnpj                  String?              @unique
  isActive              Boolean              @default(true)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  users                 User[]
  clients               Client[]
  vehicles              Vehicle[]
  budgets               Budget[]
  serviceOrders         ServiceOrder[]
  inventoryItems        InventoryItem[]
  serviceCatalogItems   ServiceCatalogItem[]
  inventoryMovements    InventoryMovement[]
  financialEntries      FinancialEntry[]
  vehicleHistoryEntries VehicleHistory[]

  @@index([isActive, createdAt])
}

model User {
  id                  String               @id @default(uuid()) @db.Uuid
  workshopId          String?              @db.Uuid
  name                String
  email               String               @unique
  passwordHash        String
  googleSubject       String?              @unique
  googleEmailVerified Boolean              @default(false)
  googleLinkedAt      DateTime?
  role                Role
  isActive            Boolean              @default(true)
  lastLoginAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  workshop            Workshop?            @relation(fields: [workshopId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  serviceOrders       ServiceOrder[]       @relation("MechanicServiceOrders")
  passwordResetTokens PasswordResetToken[]

  @@index([role, isActive])
  @@index([isActive, createdAt])
  @@index([workshopId])
  @@index([workshopId, role, isActive])
  @@index([googleSubject])
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@index([usedAt])
  @@index([revokedAt])
}

model Client {
  id               String           @id @default(uuid()) @db.Uuid
  workshopId       String           @db.Uuid
  name             String
  document         String?
  phone            String?
  email            String?
  notes            String?
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  vehicles         Vehicle[]
  budgets          Budget[]
  serviceOrders    ServiceOrder[]
  financialEntries FinancialEntry[]
  workshop         Workshop         @relation(fields: [workshopId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([workshopId, document])
  @@unique([id, workshopId])
  @@index([workshopId, name])
  @@index([workshopId, document])
  @@index([workshopId, isActive, name])
}

model Vehicle {
  id             String           @id @default(uuid()) @db.Uuid
  workshopId     String           @db.Uuid
  clientId       String           @db.Uuid
  plate          String
  brand          String
  model          String
  year           Int
  color          String?
  mileage        Int?
  fuel           String?
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  client         Client           @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  budgets        Budget[]
  serviceOrders  ServiceOrder[]
  historyEntries VehicleHistory[]
  workshop       Workshop         @relation(fields: [workshopId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([workshopId, plate])
  @@unique([id, workshopId])
  @@unique([id, clientId])
  @@unique([id, clientId, workshopId])
  @@index([workshopId, clientId])
  @@index([workshopId, plate])
  @@index([workshopId, clientId, createdAt])
}

model Budget {
  id                      String        @id @default(uuid()) @db.Uuid
  workshopId              String        @db.Uuid
  code                    String
  clientId                String        @db.Uuid
  vehicleId               String        @db.Uuid
  status                  BudgetStatus  @default(PENDENTE)
  problemDescription      String
  notes                   String?
  subtotal                Decimal       @db.Decimal(12, 2)
  discount                Decimal       @db.Decimal(12, 2)
  total                   Decimal       @db.Decimal(12, 2)
  convertedToServiceOrder Boolean       @default(false)
  approvedAt              DateTime?
  rejectedAt              DateTime?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  client                  Client        @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  vehicle                 Vehicle       @relation(fields: [vehicleId, clientId], references: [id, clientId], onDelete: Restrict, onUpdate: Cascade)
  items                   BudgetItem[]
  serviceOrder            ServiceOrder?
  workshop                Workshop      @relation(fields: [workshopId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([workshopId, code])
  @@unique([id, workshopId])
  @@index([workshopId, clientId])
  @@index([workshopId, vehicleId])
  @@index([workshopId, status])
  @@index([workshopId, clientId, status, createdAt])
  @@index([workshopId, vehicleId, status, createdAt])
}

model BudgetItem {
  id                   String              @id @default(uuid()) @db.Uuid
  budgetId             String              @db.Uuid
  serviceCatalogItemId String?             @db.Uuid
  inventoryItemId      String?             @db.Uuid
  type                 BudgetItemType
  serviceCode          String?
  description          String
  quantity             Int
  unitPrice            Decimal             @db.Decimal(12, 2)
  totalPrice           Decimal             @db.Decimal(12, 2)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  budget               Budget              @relation(fields: [budgetId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  serviceCatalogItem   ServiceCatalogItem? @relation(fields: [serviceCatalogItemId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  inventoryItem        InventoryItem?      @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([budgetId])
  @@index([budgetId, type])
  @@index([serviceCatalogItemId])
  @@index([inventoryItemId])
}

model ServiceOrder {
  id                 String              @id @default(uuid()) @db.Uuid
  workshopId         String              @db.Uuid
  orderNumber        String
  budgetId           String?             @unique @db.Uuid
  clientId           String              @db.Uuid
  vehicleId          String              @db.Uuid
  mechanicId         String?             @db.Uuid
  problemDescription String
  diagnosis          String?
  servicesPerformed  String?
  vehicleChecklist   String?
  openedAt           DateTime            @default(now())
  expectedDeliveryAt DateTime?
  finishedAt         DateTime?
  deliveredAt        DateTime?
  status             ServiceOrderStatus  @default(ABERTA)
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  budget             Budget?             @relation(fields: [budgetId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  client             Client              @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  vehicle            Vehicle             @relation(fields: [vehicleId, clientId], references: [id, clientId], onDelete: Restrict, onUpdate: Cascade)
  mechanic           User?               @relation("MechanicServiceOrders", fields: [mechanicId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  parts              ServiceOrderPart[]
  financialEntries   FinancialEntry[]
  historyEntries     VehicleHistory[]
  inventoryMovements InventoryMovement[]
  workshop           Workshop            @relation(fields: [workshopId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([workshopId, orderNumber])
  @@unique([workshopId, budgetId])
  @@unique([id, workshopId])
  @@unique([id, clientId])
  @@unique([id, clientId, workshopId])
  @@index([workshopId, clientId])
  @@index([workshopId, vehicleId])
  @@index([workshopId, mechanicId])
  @@index([workshopId, status])
  @@index([workshopId, status, openedAt])
  @@index([workshopId, vehicleId, status, openedAt])
  @@index([workshopId, mechanicId, status, openedAt])
}

model InventoryItem {
  id                String              @id @default(uuid()) @db.Uuid
  workshopId        String              @db.Uuid
  name              String
  internalCode      String
  category          String?
  supplier          String?
  quantity          Int                 @default(0)
  minimumQuantity   Int                 @default(0)
  cost              Decimal             @db.Decimal(12, 2)
  salePrice         Decimal             @db.Decimal(12, 2)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  budgetItems       BudgetItem[]
  serviceOrderParts ServiceOrderPart[]
  movements         InventoryMovement[]
  workshop          Workshop            @relation(fields: [workshopId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([workshopId, internalCode])
  @@unique([id, workshopId])
  @@index([workshopId, name])
  @@index([workshopId, internalCode])
  @@index([workshopId, category, name])
}

model ServiceCatalogItem {
  id                  String                @id @default(uuid()) @db.Uuid
  workshopId          String                @db.Uuid
  code                String
  name                String
  category            String
  description         String?
  internalNotes       String?
  laborPrice          Decimal               @db.Decimal(12, 2)
  productPrice        Decimal               @db.Decimal(12, 2)
  suggestedTotalPrice Decimal               @db.Decimal(12, 2)
  billingType         ServiceBillingType
  materialSource      ServiceMaterialSource
  warrantyDays        Int?
  active              Boolean               @default(true)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  budgetItems         BudgetItem[]
  workshop            Workshop              @relation(fields: [workshopId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([workshopId, code])
  @@unique([id, workshopId])
  @@index([workshopId, category])
  @@index([workshopId, name])
  @@index([workshopId, active])
  @@index([workshopId, createdAt])
  @@index([workshopId, active, category, name])
  @@index([workshopId, active, createdAt])
}

model ServiceOrderPart {
  id              String              @id @default(uuid()) @db.Uuid
  serviceOrderId  String              @db.Uuid
  inventoryItemId String              @db.Uuid
  quantity        Int
  unitPrice       Decimal             @db.Decimal(12, 2)
  totalPrice      Decimal             @db.Decimal(12, 2)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  serviceOrder    ServiceOrder        @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  inventoryItem   InventoryItem       @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  movements       InventoryMovement[]

  @@unique([serviceOrderId, inventoryItemId])
  @@index([serviceOrderId])
  @@index([inventoryItemId])
  @@index([inventoryItemId, createdAt])
}

model InventoryMovement {
  id                 String                @id @default(uuid()) @db.Uuid
  workshopId         String                @db.Uuid
  inventoryItemId    String                @db.Uuid
  serviceOrderId     String?               @db.Uuid
  serviceOrderPartId String?               @db.Uuid
  type               InventoryMovementType
  quantityChange     Int
  quantityBefore     Int
  quantityAfter      Int
  unitCost           Decimal?              @db.Decimal(12, 2)
  totalCost          Decimal?              @db.Decimal(12, 2)
  reason             String?
  createdAt          DateTime              @default(now())
  inventoryItem      InventoryItem         @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  serviceOrder       ServiceOrder?         @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  serviceOrderPart   ServiceOrderPart?     @relation(fields: [serviceOrderPartId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  workshop           Workshop              @relation(fields: [workshopId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([workshopId, inventoryItemId, createdAt])
  @@index([workshopId, serviceOrderId])
  @@index([workshopId, serviceOrderPartId])
  @@index([workshopId, type, createdAt])
}

model FinancialEntry {
  id             String             @id @default(uuid()) @db.Uuid
  workshopId     String             @db.Uuid
  type           FinancialEntryType
  description    String
  category       String
  amount         Decimal            @db.Decimal(12, 2)
  dueDate        DateTime
  paidAt         DateTime?
  paymentMethod  PaymentMethod?
  status         FinancialStatus    @default(PENDENTE)
  clientId       String?            @db.Uuid
  serviceOrderId String?            @db.Uuid
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  client         Client?            @relation(fields: [clientId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  serviceOrder   ServiceOrder?      @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  workshop       Workshop           @relation(fields: [workshopId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([id, workshopId])
  @@index([workshopId, type])
  @@index([workshopId, status])
  @@index([workshopId, dueDate])
  @@index([workshopId, clientId])
  @@index([workshopId, serviceOrderId])
  @@index([workshopId, status, dueDate])
  @@index([workshopId, type, status, dueDate])
}

model VehicleHistory {
  id              String        @id @default(uuid()) @db.Uuid
  workshopId      String        @db.Uuid
  vehicleId       String        @db.Uuid
  serviceOrderId  String?       @unique @db.Uuid
  entryDate       DateTime
  mileage         Int?
  servicesSummary String
  partsSummary    String?
  totalAmount     Decimal?      @db.Decimal(12, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  vehicle         Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  serviceOrder    ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  workshop        Workshop      @relation(fields: [workshopId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([workshopId, serviceOrderId])
  @@index([workshopId, vehicleId, entryDate])
  @@index([workshopId, entryDate])
}
