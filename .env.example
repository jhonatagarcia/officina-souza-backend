NODE_ENV=development
PORT=3000
APP_NAME=Oficina Backend API
APP_VERSION=1.0.0
API_PREFIX=api

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public

JWT_SECRET=REPLACE_WITH_A_RANDOM_SECRET_WITH_AT_LEAST_32_CHARACTERS
JWT_EXPIRES_IN=15m
JWT_ISSUER=oficina-backend-api
JWT_AUDIENCE=oficina-web

BCRYPT_SALT_ROUNDS=12

CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=false

THROTTLE_TTL=60
THROTTLE_LIMIT=100

LOG_LEVEL=debug
ENABLE_SWAGGER=true

WHATSAPP_ACCESS_TOKEN=REPLACE_WITH_WHATSAPP_CLOUD_API_TOKEN
WHATSAPP_PHONE_NUMBER_ID=REPLACE_WITH_WHATSAPP_PHONE_NUMBER_ID
WHATSAPP_API_VERSION=v21.0
WHATSAPP_TEMPLATE_LANGUAGE=pt_BR
WHATSAPP_TEMPLATE_SERVICE_ORDER_IN_PROGRESS=ordem_em_andamento
WHATSAPP_TEMPLATE_SERVICE_ORDER_FINISHED=ordem_finalizada
WHATSAPP_TEMPLATE_SERVICE_ORDER_DELIVERED=ordem_entregue

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=REPLACE_WITH_A_LOCAL_ADMIN_PASSWORD
SEED_ADMIN_NAME=Admin
