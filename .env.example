NODE_ENV=development
PORT=3000
APP_NAME=Oficina Backend API
APP_VERSION=1.0.0
API_PREFIX=api

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/oficina_db?schema=public

JWT_SECRET=REPLACE_WITH_A_RANDOM_SECRET_WITH_AT_LEAST_32_CHARACTERS
JWT_EXPIRES_IN=15m
JWT_ISSUER=oficina-backend-api
JWT_AUDIENCE=oficina-web

BCRYPT_SALT_ROUNDS=12
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
PASSWORD_RESET_APP_URL=http://localhost:5173/reset-password
PASSWORD_RESET_EMAIL_PROVIDER=noop
# PASSWORD_RESET_EMAIL_FROM=no-reply@oficina.local
# PASSWORD_RESET_EMAIL_PROVIDER=webhook
# PASSWORD_RESET_EMAIL_WEBHOOK_URL=https://seu-site.com/api/send-email
# Gere com: openssl rand -hex 32
# PASSWORD_RESET_EMAIL_WEBHOOK_TOKEN=
CAPTCHA_ENABLED=false
# CAPTCHA_PROVIDER=turnstile
# CAPTCHA_SECRET=
# CAPTCHA_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify
# CAPTCHA_EXPECTED_ACTION=none

CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=false

THROTTLE_TTL=60
THROTTLE_LIMIT=100

LOG_LEVEL=debug
ENABLE_SWAGGER=true

GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_OAUTH_CLIENT_ID
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/callback/google

QUEUE_PREFIX=oficina_local
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_TLS=false
QUEUE_WHATSAPP_ATTEMPTS=5
QUEUE_WHATSAPP_BACKOFF_DELAY_MS=5000

WHATSAPP_API_VERSION=v25.0
WHATSAPP_TEMPLATE_LANGUAGE=pt_BR
WHATSAPP_TEMPLATE_HEADER_TEXT=Oficina Paiva
WHATSAPP_TEMPLATE_SERVICE_ORDER_IN_PROGRESS=ordem_em_andamento
WHATSAPP_TEMPLATE_SERVICE_ORDER_FINISHED=ordem_finalizada
WHATSAPP_TEMPLATE_SERVICE_ORDER_DELIVERED=ordem_entregue

# Configure apenas quando a integracao real do WhatsApp estiver ativa.
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# META_APP_SECRET=

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=REPLACE_WITH_A_LOCAL_ADMIN_PASSWORD
SEED_ADMIN_NAME=Admin
